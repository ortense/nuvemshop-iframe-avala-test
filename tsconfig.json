{
  "compilerOptions": {
    "target": "es2016",
    "jsx": "react-jsx",
    "jsxImportSource": "@tiendanube/nube-sdk-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true
  },
  "include": [
    "./src/**/*"
  ]
}
